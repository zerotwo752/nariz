DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Neon: pega solo la URL postgresql://..., sin anteponer psql ni envolverla en comillas.
JWT_SECRET=change-this-long-random-secret
CORS_ORIGIN=http://localhost:5173
PORT=4000

# Pega solo la clave, sin curl, sin comillas y sin el prefijo Bearer.
GEMINI_API_KEY=your-gemini-api-key
# Usa el mismo modelo que muestra Google AI Studio o deja el valor por defecto del código.
GEMINI_MODEL=gemini-flash-latest
